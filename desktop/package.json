{
    "name": "securenotes",
    "version": "2.0.0",
    "description": "SecureNotes - Aplicación de notas seguras by PierceMyCode",
    "main": "main.js",
    "author": "PierceMyCode",
    "license": "MIT",
    "private": true,
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build:win": "electron-builder --win",
        "build:mac": "electron-builder --mac",
        "build:linux": "electron-builder --linux",
        "build:all": "electron-builder --win --mac --linux",
        "dist": "electron-builder",
        "postinstall": "electron-builder install-app-deps"
    },
    "build": {
        "appId": "com.piercemycode.securenotes",
        "productName": "SecureNotes",
        "copyright": "Copyright © 2026 PierceMyCode",
        "directories": {
            "output": "release",
            "buildResources": "icons"
        },
        "files": [
            "main.js",
            "preload.js",
            "../web/**/*"
        ],
        "extraMetadata": {
            "main": "main.js"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": ["x64", "ia32"]
                },
                {
                    "target": "portable",
                    "arch": ["x64"]
                }
            ],
            "icon": "icons/icon.ico",
            "artifactName": "SecureNotes-${version}-Setup-${arch}.${ext}",
            "publisherName": "PierceMyCode"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "deleteAppDataOnUninstall": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "SecureNotes",
            "installerHeader": "Instalando SecureNotes...",
            "installerIcon": "icons/icon.ico",
            "uninstallerIcon": "icons/icon.ico",
            "license": "../LICENSE.txt"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": ["x64", "arm64"]
                },
                {
                    "target": "zip",
                    "arch": ["x64", "arm64"]
                }
            ],
            "icon": "icons/icon.icns",
            "artifactName": "SecureNotes-${version}-${arch}.${ext}",
            "category": "public.app-category.productivity",
            "darkModeSupport": true,
            "hardenedRuntime": true
        },
        "dmg": {
            "title": "SecureNotes ${version}",
            "background": null,
            "icon": "icons/icon.icns",
            "iconSize": 128,
            "window": {
                "width": 540,
                "height": 380
            },
            "contents": [
                { "x": 130, "y": 200, "type": "file" },
                { "x": 410, "y": 200, "type": "link", "path": "/Applications" }
            ]
        },
        "linux": {
            "target": [
                { "target": "AppImage", "arch": ["x64"] },
                { "target": "deb", "arch": ["x64"] },
                { "target": "rpm", "arch": ["x64"] }
            ],
            "icon": "icons",
            "artifactName": "SecureNotes-${version}-${arch}.${ext}",
            "category": "Office",
            "synopsis": "Secure Notes Application",
            "description": "Aplicación de notas seguras con cifrado local y sincronización en la nube",
            "packageCategory": "Office",
            "maintainer": "PierceMyCode"
        },
        "publish": {
            "provider": "github",
            "owner": "PierceMyCode",
            "repo": "SecureNotes",
            "releaseType": "release"
        }
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.0"
    }
}